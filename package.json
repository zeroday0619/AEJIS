    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.9",
    "@cloudflare/workers-types": "^4.20260415.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "autoprefixer": "^10.4.20",
    "daisyui": "^4.12.22",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vercel": "^51.7.0",
    "wrangler": "^4.11.1"
  }
